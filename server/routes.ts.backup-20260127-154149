            accountType: accountType.toLowerCase() as "checking" | "savings",
            routingNumber: routingNumber ?? null,
            accountNumber: accountNumber ?? null,
          }],
        });
        counterpartyId = counterparty.id;
        
        // Get the external account ID
        if (counterparty.accounts && counterparty.accounts.length > 0) {
          externalAccountId = counterparty.accounts[0].id ?? null;
        }
      } else {
        // Add external account to existing counterparty
        const externalAccount = await modernTreasuryService.createExternalAccount({
          counterpartyId,
          accountType: accountType.toLowerCase() as "checking" | "savings",
          routingNumber,
          accountNumber,
          name: bankName || "Bank Account",
        });
        externalAccountId = externalAccount.id;
      }

      // Store bank info on worker profile (Modern Treasury)
      await storage.updateProfile(profile.id, {
        mtCounterpartyId: counterpartyId,
        mtExternalAccountId: externalAccountId,
        mtBankVerified: false,
        bankAccountLinked: !!counterpartyId,
      });

      // Also store in payout_accounts table
      await storage.createPayoutAccount({
        profileId: profile.id,
        provider: "modern_treasury",
        externalAccountId: externalAccountId || counterpartyId || `pending_${profile.id}`,
        accountType: accountType,
        bankName: bankName || "Bank Account",
        accountLastFour: lastFour,
        isDefault: true,
      });

      // AUTO-RELEASE: Process any pending payouts held in escrow for this worker
      let releasedPayouts: any[] = [];
      try {
        const pendingPayouts = await storage.getWorkerPayoutsByStatus(profile.id, "pending_bank_setup");
        console.log(`[PayoutAccountSetup] Found ${pendingPayouts.length} pending payouts for worker ${profile.id}`);
        
        if (pendingPayouts.length > 0 && externalAccountId && counterpartyId) {
          const { getPlatformInternalAccountId } = await import("./services/modernTreasury");
          const platformAccountId = await getPlatformInternalAccountId();
          
          for (const payout of pendingPayouts) {
            try {
              console.log(`[PayoutAccountSetup] Processing escrow payout ${payout.id} - $${(payout.amount/100).toFixed(2)}`);
              
              // ACH credit: Send funds FROM platform account TO worker's bank
              const paymentOrder = await modernTreasuryService.createACHCredit({
                originatingAccountId: platformAccountId,
                counterpartyId: counterpartyId,
                receivingAccountId: externalAccountId,
                amount: payout.amount,
                description: `Escrow release - ${payout.description || 'Timesheet payout'}`,
                metadata: {
                  workerId: profile.id.toString(),
                  payoutId: payout.id.toString(),
                  type: "escrow_release",
                }
              });
              
              // Update payout record
              await storage.updateWorkerPayout(payout.id, {
                status: "processing",
                mtPaymentOrderId: paymentOrder.id,
                mtPaymentStatus: paymentOrder.status,
              });
              
              // Update timesheet payment status
              if (payout.timesheetId) {
                await storage.updateTimesheet(payout.timesheetId, {
                  paymentStatus: "pending", // Will become completed via webhook
                });
              }
              
              releasedPayouts.push({
                id: payout.id,
                amount: payout.amount / 100,
                status: "processing"
              });
              
              console.log(`[PayoutAccountSetup] Released escrow payout ${payout.id} - Payment Order: ${paymentOrder.id}`);
            } catch (payoutErr) {
              console.error(`[PayoutAccountSetup] Failed to release payout ${payout.id}:`, payoutErr);
            }
          }
        }
      } catch (escrowErr) {
        console.error("[PayoutAccountSetup] Error processing escrow payouts:", escrowErr);
      }

      res.json({ 
        success: true, 
        lastFour, 
        counterpartyId,
        externalAccountId,
        releasedPayouts: releasedPayouts.length > 0 ? releasedPayouts : undefined,
        message: releasedPayouts.length > 0 
          ? `Bank account added. ${releasedPayouts.length} pending payment(s) totaling $${releasedPayouts.reduce((s, p) => s + p.amount, 0).toFixed(2)} are now being processed.`
          : "Bank account added successfully."
      });
    } catch (err: any) {
      console.error("Worker payout account setup error:", err);
      res.status(500).json({ message: err.message });
    }
  });

