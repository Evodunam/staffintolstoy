          to: email,
          type: "otp_login",
          data: {
            otpCode,
            firstName: user.firstName || "User",
          },
        });

        res.json({ 
          success: true, 
          userExists: true,
          message: "OTP code sent to your email", 
          showOtpInput: true 
        });
      }
