        await sendEmail({
          to: email,
          type: "otp_and_magic_link_login",
          data: {
            otpCode,
            magicLink,
            firstName: user.firstName || "User",
          },
        });

        res.json({ 
          success: true, 
          userExists: true,
          message: "Login code and magic link sent to your email", 
          showOtpInput: true 
        });
