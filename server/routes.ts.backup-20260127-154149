  app.post("/api/unit/auto-charge", async (req, res) => {
    if (!req.isAuthenticated()) return res.status(401).json({ message: "Unauthorized" });
    const user = req.user as any;
    const profile = await storage.getProfileByUserId(user.claims.sub);
    if (!profile || profile.role !== "company") {
      return res.status(403).json({ message: "Only companies can trigger auto-charge" });
    }

    const { jobId } = req.body;

    try {
      const unitService = (await import("./services/unit")).default;

      // Calculate committed funds for the job
      const job = jobId ? await storage.getJob(jobId) : null;
      
      if (!profile.unitAccountId || !profile.unitCounterpartyId) {
        return res.status(400).json({ message: "Company payment not configured" });
      }

      // Get current Unit balance
      const balance = await unitService.getAccountBalance(profile.unitAccountId);
      
      // Calculate required funds based on approved workers for job
      let requiredFunds = 0;
      if (job) {
        const approvedApplications = await storage.getApplicationsByJob(job.id);
        const approved = approvedApplications.filter(a => a.status === "accepted");
        requiredFunds = approved.length * (job.hourlyRate || 0) * (job.estimatedHours || 8);
      }

      // If balance is insufficient, charge the difference
      const shortfall = requiredFunds - balance.available;
      if (shortfall > 0) {
        const paymentResult = await unitService.createACHPayment({
          accountId: profile.unitAccountId,
          counterpartyId: profile.unitCounterpartyId,
          amount: shortfall,
          direction: "Debit",
          description: "Auto-chrg",
          tags: { profileId: profile.id.toString(), jobId: jobId?.toString(), type: "auto_recharge" },
        });

        await storage.createCompanyTransaction({
          profileId: profile.id,
          type: "auto_recharge",
          amount: shortfall,
          description: `Auto-charge for job ${job?.title || jobId}`,
          jobId,
          paymentMethod: "ach",
          unitPaymentId: paymentResult.data.id,
          unitPaymentStatus: paymentResult.data.attributes.status,
        });

        res.json({ charged: true, amount: shortfall, payment: paymentResult.data });
      } else {
        res.json({ charged: false, message: "Sufficient balance available" });
      }
    } catch (err: any) {
      console.error("Unit auto-charge error:", err);
      res.status(500).json({ message: err.message });
    }
  });

