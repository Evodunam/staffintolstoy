  app.post("/api/geolocation/ip", async (req, res) => {
    try {
      const apiKey = process.env.GOOGLE_API_KEY;
      if (!apiKey) {
        // Return 200 with error flag instead of 400, so client can gracefully fall back
        return res.status(200).json({ 
          error: "Geolocation service not configured",
          configured: false 
        });
      }
      
      // Use Google Geolocation API (IP-based)
      const response = await fetch(`https://www.googleapis.com/geolocation/v1/geolocate?key=${apiKey}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ considerIp: true }),
      });
      
      if (response.ok) {
        const data = await response.json();
        if (data.location?.lat && data.location?.lng) {
          res.json({
            latitude: data.location.lat,
            longitude: data.location.lng,
            accuracy: data.accuracy,
            source: "google_ip",
          });
        } else {
          res.status(200).json({ 
            error: "Could not determine location from IP",
            configured: true 
          });
        }
      } else {
        const errorData = await response.json().catch(() => ({}));
        res.status(200).json({ 
          error: errorData.error?.message || "Could not determine location from IP",
          configured: true 
        });
      }
    } catch (err) {
